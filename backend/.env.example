# ─────────────────── Server ───────────────────
# PORT is auto-set by Render in production — DO NOT set it here in production.
# For local dev, the app falls back to 4000 if PORT is missing/empty.
PORT=4000

# Comma-separated list — useful for adding Vercel preview URLs without redeploying.
# Example prod value: https://broadcast.vercel.app,https://broadcast-git-dev-yourteam.vercel.app
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174

# ─────────────────── Database ───────────────────
# Copy this file to .env locally and fill in your MongoDB connection string.
# In production, MONGODB_URI is REQUIRED — no silent fallback to localhost.
# Make sure MongoDB Atlas → Network Access allows 0.0.0.0/0 (or Render's IPs).
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/broadcast

# ─────────────────── Auth ───────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In production, JWT_SECRET is REQUIRED — boot fails with a clear error if missing.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─────────────────── Facebook Messenger ───────────────────
# https://developers.facebook.com → My Apps → your app → App Settings → Basic
FB_APP_ID=
FB_APP_SECRET=
# Any string — used to verify the webhook URL during Meta's setup wizard.
FB_VERIFY_TOKEN=broadcast_verify_2026
# Where Facebook returns the user after login.
FB_OAUTH_REDIRECT=http://localhost:5173/auth/facebook/callback

# ─────────────────── WhatsApp Cloud API ───────────────────
# Same Meta app — add the WhatsApp product. The Cloud API gives a free test number.
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
# Permanent System User token via Meta Business Manager; or a 24h Temporary token for dev.
WA_ACCESS_TOKEN=
# Any string — used to verify the WhatsApp webhook URL.
WA_VERIFY_TOKEN=broadcast_wa_2026
