# ─────────────────── Server ───────────────────
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174

# ─────────────────── Database ───────────────────
# Copy this file to .env and fill in your MongoDB connection string.
# DO NOT commit the actual URI back to .env.example.
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/broadcast

# ─────────────────── Auth ───────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─────────────────── Facebook Messenger ───────────────────
# https://developers.facebook.com → My Apps → your app → App Settings → Basic
FB_APP_ID=1555976936244590
FB_APP_SECRET=6b49799d507f0871d82a8461b069188e
# Pick any string — used to verify the webhook URL during Meta's setup wizard.
FB_VERIFY_TOKEN=broadcast_verify_2026
# Where Facebook returns the user after login.
FB_OAUTH_REDIRECT=http://localhost:5173/auth/facebook/callback

# ─────────────────── WhatsApp Cloud API ───────────────────
# Same Meta app — add the WhatsApp product. The Cloud API gives you a free test number.
# https://developers.facebook.com → your app → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
# Permanent System User token via Meta Business Manager; or a 24h Temporary token for dev.
WA_ACCESS_TOKEN=
# Pick any string — used to verify the WhatsApp webhook URL.
WA_VERIFY_TOKEN=broadcast_wa_2026
