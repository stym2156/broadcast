# Admin env — Vite reads `VITE_*` vars at build time only (not at runtime).
# In Vercel: set on the project's Environment Variables page BEFORE first build.
# Changing this in Vercel requires triggering a new deploy to take effect.

VITE_API_URL=http://localhost:4000/api
# Production example: VITE_API_URL=https://broadcast-api-kwe6.onrender.com/api
